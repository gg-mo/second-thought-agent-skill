#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
SKILL_FILE="${ROOT_DIR}/skills/using-are-you-sure/SKILL.md"

if [ ! -f "$SKILL_FILE" ]; then
  printf '{"additionalContext":""}\n'
  exit 0
fi

escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

CONTENT="$(cat "$SKILL_FILE")"
CONTENT_ESCAPED="$(escape_for_json "$CONTENT")"
BOOTSTRAP="<EXTREMELY_IMPORTANT>\\nYou have Are You Sure.\\n\\nApply this skill before major commitments or actions.\\n\\n${CONTENT_ESCAPED}\\n</EXTREMELY_IMPORTANT>"

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{"additional_context":"%s"}\n' "$BOOTSTRAP"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"}}\n' "$BOOTSTRAP"
else
  printf '{"additionalContext":"%s"}\n' "$BOOTSTRAP"
fi
